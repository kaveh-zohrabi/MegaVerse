# MegaVerse EditorConfig
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.{go,rs}]
indent_size = 4

[*.{java,kt}]
indent_size = 4

[*.{py}]
indent_size = 4

[*.{c,cpp,h,hpp}]
indent_size = 4

[*.{zig}]
indent_size = 4

[*.{dart}]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.{json}]
indent_size = 2

[*.{xml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[Dockerfile]
indent_size = 4

[*.tf]
indent_size = 2
