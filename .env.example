# MegaVerse Environment Variables

# General
NODE_ENV=development
APP_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_NAME=megaverse
APP_VERSION=0.1.0
LOG_LEVEL=debug
LOG_FORMAT=json

# Database - PostgreSQL
DATABASE_URL=postgres://megaverse:password@localhost:5432/megaverse
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=megaverse
DATABASE_USER=megaverse
DATABASE_PASSWORD=password
DATABASE_SSL=false
DATABASE_POOL_SIZE=20

# Database - MongoDB
MONGODB_URL=mongodb://localhost:27017/megaverse
MONGODB_NAME=megaverse

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=megaverse
KAFKA_AUTO_OFFSET_RESET=earliest

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# API Gateway
GATEWAY_PORT=8080
GATEWAY_RATE_LIMIT=1000
GATEWAY_RATE_WINDOW=60

# AI Service
AI_SERVICE_URL=http://localhost:8081
AI_MODEL_DIR=./ai/models
AI_EMBEDDING_DIM=1536
AI_VECTOR_DB_URL=http://localhost:8082

# Storage
S3_BUCKET=megaverse-storage
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:4566

# Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@megaverse.dev

# Payment (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (Communication)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_PORT=14268

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_MARKETPLACE_ENABLED=true
FEATURE_LIVE_STREAMING=false
